3.light sensetive sensor

int lightSensorValue = 0;

void setup()
{
  pinMode(A0, INPUT);     // LDR connected to A0
  pinMode(9, OUTPUT);     // LED connected to pin 9
  Serial.begin(9600);     // Start serial communication
}

void loop()
{
  lightSensorValue = analogRead(A0);   // Read LDR value
  Serial.println(lightSensorValue);    // Print value

  int ledBrightness = map(lightSensorValue, 0, 1023, 0, 255);

  analogWrite(9, ledBrightness);       // Control LED brightness

  delay(100);
}

