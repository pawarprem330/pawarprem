1.servo motar

#include <Servo.h>   // Correct library

Servo servoBase;     // Create servo object

void setup()
{
  servoBase.attach(9);   // Connect servo to pin 9
}

void loop()
{
  // Move from 0 to 180 degrees
  for (int i = 0; i <= 180; i++)
  {
    servoBase.write(i);
    delay(20);
  }

  // Move back from 180 to 0 degrees
  for (int i = 180; i >= 0; i--)
  {
    servoBase.write(i);
    delay(20);
  }
}

