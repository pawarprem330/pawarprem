5.ultra sonic sensor
const int trigPin = 9;
const int echoPin = 10;

long duration;
int distance;

void setup()
{
  Serial.begin(9600);

  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
}

void loop()
{
  // Clear trigger
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  // Send pulse
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  // Read echo time
  duration = pulseIn(echoPin, HIGH);

  // Calculate distance
  distance = duration * 0.034 / 2;

  Serial.print("Distance: ");
  Serial.print(distance);
  Serial.println(" cm");

  delay(500);
}


6.udigital infared motion sensor 

int sensorState = 0;
int pirPin = 2;   // PIR sensor connected to pin 2

void setup()
{
  pinMode(pirPin, INPUT);
  pinMode(LED_BUILTIN, OUTPUT);
}

void loop()
{
  sensorState = digitalRead(pirPin);

  if (sensorState == HIGH)
  {
    digitalWrite(LED_BUILTIN, HIGH);   // Motion detected → LED ON
  }
  else
  {
    digitalWrite(LED_BUILTIN, LOW);    // No motion → LED OFF
  }

  delay(100);
}


7. gas sensor 

int LED = 13;           // LED pin
int mq2_pin = A0;       // MQ2 sensor pin
int sensorValue = 0;

void setup()
{
  pinMode(LED, OUTPUT);
  Serial.begin(9600);
}

void loop()
{
  sensorValue = analogRead(mq2_pin);   // Read gas sensor value

  if (sensorValue > 470)
  {
    digitalWrite(LED, HIGH);           // Gas detected → LED ON
    Serial.print("Sensor Value: ");
    Serial.println(sensorValue);
    Serial.println("SMOKE DETECTED");
  }
  else
  {
    digitalWrite(LED, LOW);            // No gas → LED OFF
    Serial.print("Sensor Value: ");
    Serial.println(sensorValue);
  }

  delay(500);
}
